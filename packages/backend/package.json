    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/passport-google-oauth20": "^2.0.14",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^5.22.0",
    "typescript": "^5.6.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2"
